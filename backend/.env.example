# ─────────────────────────────────────────────────────────────
# Tarlac Tourism Inventory Supply Data System — Environment
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local:  mongodb://localhost:27017/tarlac_tourism
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/tarlac_tourism
MONGODB_URI=mongodb://localhost:27017/tarlac_tourism

# JWT Authentication
JWT_SECRET=tarlac_tourism_secret_key_2026_change_this_in_production
JWT_EXPIRE=7d

# For Production Deployment
# Set this to your frontend URL (e.g., https://tarlac-tourism.vercel.app)
FRONTEND_URL=http://localhost:3000
