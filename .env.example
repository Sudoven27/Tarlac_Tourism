# ─────────────────────────────────────────────────────────────
# Tarlac Tourism System — Environment Configuration
# Copy this file to backend/.env  (the backend reads it from there)
# ─────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# MongoDB — Local or Atlas
MONGODB_URI=mongodb://localhost:27017/tarlac_tourism

# JWT
JWT_SECRET=tarlac_tourism_secret_key_2026_change_this_in_production
JWT_EXPIRE=7d
